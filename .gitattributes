# Repository-wide line ending policy
* text=auto eol=lf

# Windows scripts keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Common source and config files keep LF
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.java text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.html text eol=lf
